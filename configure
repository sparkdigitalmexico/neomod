  e) ax_cv_check_cxxflags___gcodeview=no ;;
esac
fi
rm -f core conftest.err conftest.$ac_objext conftest.beam conftest.$ac_ext
  CXXFLAGS=$ax_check_save_flags ;;
esac
fi
{ printf '%s\n' "$as_me:${as_lineno-$LINENO}: result: $ax_cv_check_cxxflags___gcodeview" >&5
printf '%s\n' "$ax_cv_check_cxxflags___gcodeview" >&6; }
