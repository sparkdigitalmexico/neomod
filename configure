# gdwarf-5 isn't supported by a lot of tools/debuggers outside linux
if test "$SYSNAME" = "linux"
then :
  _gdwarf_version="-gdwarf-5"
else case e in #(
  e) _gdwarf_version="-gdwarf-4" ;;
esac
fi

if test "x$enable_debug" = "xyes"
then :

    if test "x$with_mimalloc" != "xyes"
then :
  with_mimalloc=no
fi
    if test "$host_os" = "mingw32"
then :

        # make the exe open with a console window
        if test "x$enable_clang" = "xyes"
then :

            NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -Wl,--subsystem,console:${win_subsystem_ver}"

            CXXFLAGS="$CXXFLAGS -g3 -Og"
            CFLAGS="$CFLAGS -g3 -Og"

else case e in #(
  e)
            NEOMOD_COMPFLAGS="$NEOMOD_COMPFLAGS -mconsole"
            NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -mconsole -Wl,--subsystem,console:${win_subsystem_ver}"

            CXXFLAGS="$CXXFLAGS -g3 -ggdb3 $_gdwarf_version -Og"
            CFLAGS="$CFLAGS -g3 -ggdb3 $_gdwarf_version -Og"
         ;;
esac
fi

else case e in #(
  e)
        # don't remap paths, the source should correspond to the real source location on linux
        # non-mingw
        CXXFLAGS="$CXXFLAGS -g3 -ggdb3 $_gdwarf_version -Og"
        CFLAGS="$CFLAGS -g3 -ggdb3 $_gdwarf_version -Og"
     ;;
esac
fi
    if test -n "$WASM_CC"
then :

        CXXFLAGS="$CXXFLAGS -gsource-map"
        CFLAGS="$CFLAGS -gsource-map"
        LDFLAGS="$LDFLAGS -gsource-map"

fi

    ENABLE_DEBUG=$enable_debug
    NEOMOD_CPPFLAGS="$NEOMOD_CPPFLAGS -D_DEBUG"
    if test -z "$CLANG" && test -z "$WASM_CC"
then :

        NEOMOD_COMPFLAGS="$NEOMOD_COMPFLAGS -Wcast-align -Wpacked-not-aligned"
        # CPPFLAGS="$CPPFLAGS -D_GLIBCXX_DEBUG"
        # CXXFLAGS="$CXXFLAGS -D_GLIBCXX_DEBUG"

fi
    # assertions breaks in a couple places due to calling malloc/free in the soloud mixer (inside SoundTouch)
    # hopefully it's not fatal to ignore...
    # AS_IF([test -n "$WASM_CC"], [
    #     NEOMOD_COMPFLAGS="$NEOMOD_COMPFLAGS -sASSERTIONS"
    #     NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -sASSERTIONS"
    # ])

    if test "x$enable_strip" != "xyes"
then :
  enable_strip=no
fi # disable stripping unless its explicitly requested for debug (why tho?)

else case e in #(
  e)
    if test "x$enable_optimize" != "xno"
then :

        CPPFLAGS="$CPPFLAGS -DNDEBUG -D_NDEBUG"
        # put it at the start so -O3 is overrideable from the command line
        CXXFLAGS="-O3 $(printf '%s' "$CXXFLAGS" | $SED 's/-O2//g')" # where do those -g -O2 flags even come from...
        CFLAGS="-O3 $(printf '%s' "$CFLAGS" | $SED 's/-O2//g')"
        NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -Wl,-O1"

        if test "x$enable_clang" != "xyes" && test -z "$WASM_CC"
then :

            # -fipa-pta is GCC-only, skip for clang and emscripten
            CXXFLAGS="$CXXFLAGS -fipa-pta"
            CFLAGS="$CFLAGS -fipa-pta"

fi

fi
    if test "x$enable_strip" != "xno"
then :

        if test "$SYSNAME" != "macos"
then :

            NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -Wl,-s" # strip flag (ld64 considers this obsolete, so just rely on post-link strip)

fi

else case e in #(
  e)
        if test -z "$WASM_CC"
then :

            # add minimal debug info
            CXXFLAGS="-g $_gdwarf_version $CXXFLAGS"
            CFLAGS="-g $_gdwarf_version $CFLAGS"

fi
     ;;
esac
fi
    if test "$host_os" = "mingw32"
then :

        if test "x$enable_clang" = "xyes"
then :

            NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -Wl,--subsystem,windows:${win_subsystem_ver}"

else case e in #(
  e)
            NEOMOD_COMPFLAGS="$NEOMOD_COMPFLAGS -mwindows"
            NEOMOD_LDFLAGS="$NEOMOD_LDFLAGS -mwindows -Wl,--subsystem,windows:${win_subsystem_ver}"
         ;;
esac
fi

fi
 ;;
esac
fi

