printf '%s\n' "#define PACKAGE_STRING \"$PACKAGE_STRING\"" >>confdefs.h

printf '%s\n' "#define PACKAGE_BUGREPORT \"$PACKAGE_BUGREPORT\"" >>confdefs.h

printf '%s\n' "#define PACKAGE_URL \"$PACKAGE_URL\"" >>confdefs.h


