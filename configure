    libX11              ${have_x11-no}
    libXi (XInput)      ${have_xi-no}
    xrandr              ${have_xrandr-no}
    libGL               ${have_gl-no}
    libGLU              ${have_glu-no}
    libEGL              ${have_egl-no}
    sdl3:               ${have_sdl3-build from source}
