  ac_save_IFS=$IFS
        IFS=' ,'
        set x $with_audio
        IFS=$ac_save_IFS
        shift
        for aud
        do
            case $aud in
            soloud*) with_soloud=yes ;;
            bass*) with_bass=yes ;;
            esac
        done
fi

if test "$with_bass" = "yes" && ! { test "$host_cpu" = "x86_64" || test "$host_cpu" = "i686" ; }
then :

    { printf '%s\n' "$as_me:${as_lineno-$LINENO}: BASS is currently unsupported on $host_cpu. Using SoLoud." >&5
printf '%s\n' "$as_me: BASS is currently unsupported on $host_cpu. Using SoLoud." >&6;}
    with_bass=no

fi

if test "$with_soloud" = "yes" || { test "$with_soloud" = "unset" && test "$with_bass" != "yes"; }
then :

    AUDBACKENDLIST="${AUDBACKENDLIST} SoLoud"
    with_soloud=yes

printf '%s\n' "#define MCENGINE_FEATURE_SOLOUD 1" >>confdefs.h


else case e in #(
  e)
    with_soloud=no
 ;;
esac
fi

if test "$with_bass" = "yes"
then :

    if test "$with_soloud" = "yes"
then :

        make_audio_shortcuts=yes

fi
    AUDBACKENDLIST="${AUDBACKENDLIST} BASS"

printf '%s\n' "#define MCENGINE_FEATURE_BASS 1" >>confdefs.h


else case e in #(
  e)
    with_bass=no
 ;;
esac
