	$(DEPS_PREFIX)/winpthread-noversion.built \
	$(DEPS_PREFIX)/mimalloc-$(MIMALLOC_VERSION).built \
	$(DEPS_PREFIX)/SDL3-$(SDL3_VERSION).built \
