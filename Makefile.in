$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassasio.zip:
	$(MKDIR_P) $(DEPS_CACHE)/bass-$(BASS_VERSION) && \
	$(CURLCOMMAND) "https://archive.org/download/bass-libs-$(BASS_VERSION)/bassasio.zip" || { rm -f $@; exit 1; }

# windows builds: only need windows zips
$(DEPS_CACHE)/bass-$(BASS_VERSION)-windows.source: $(DEPS_CACHE)/bass-$(BASS_VERSION)/bass.zip $(DEPS_CACHE)/bass-$(BASS_VERSION)/bass24-header.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassflac24.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bass_fx.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassmix.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassloud24.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/basswasapi.zip $(DEPS_CACHE)/bass-$(BASS_VERSION)/basswasapi24-header.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassasio.zip
	cd $(DEPS_CACHE)/bass-$(BASS_VERSION) && \
	$(MKDIR_P) bass/lib/windows/i686 && $(UNZIP) -qjo bass.zip bass.dll -d bass/lib/windows/i686 && \
	$(MKDIR_P) bass/lib/windows/x86_64 && $(UNZIP) -qjo bass.zip x64/bass.dll -d bass/lib/windows/x86_64 && \
	$(MKDIR_P) bass/include/ && $(UNZIP) -qjo bass24-header.zip c/bass.h -d bass/include/ && \
	$(MKDIR_P) bassfx/lib/windows/i686 && $(UNZIP) -qjo bass_fx.zip bass_fx.dll -d bassfx/lib/windows/i686 && \
	$(MKDIR_P) bassfx/lib/windows/x86_64 && $(UNZIP) -qjo bass_fx.zip x64/bass_fx.dll -d bassfx/lib/windows/x86_64 && \
	$(MKDIR_P) bassfx/include/ && $(UNZIP) -qjo bass_fx.zip bass_fx.h -d bassfx/include/ && \
	$(MKDIR_P) bassflac/lib/windows/i686 && $(UNZIP) -qjo bassflac24.zip bassflac.dll -d bassflac/lib/windows/i686 && \
	$(MKDIR_P) bassflac/lib/windows/x86_64 && $(UNZIP) -qjo bassflac24.zip x64/bassflac.dll -d bassflac/lib/windows/x86_64 && \
	$(MKDIR_P) bassmix/lib/windows/i686 && $(UNZIP) -qjo bassmix.zip bassmix.dll -d bassmix/lib/windows/i686 && \
	$(MKDIR_P) bassmix/lib/windows/x86_64 && $(UNZIP) -qjo bassmix.zip x64/bassmix.dll -d bassmix/lib/windows/x86_64 && \
	$(MKDIR_P) bassmix/include/ && $(UNZIP) -qjo bassmix.zip bassmix.h -d bassmix/include/ && \
	$(MKDIR_P) bassloud/lib/windows/i686 && $(UNZIP) -qjo bassloud24.zip bassloud.dll -d bassloud/lib/windows/i686 && \
	$(MKDIR_P) bassloud/lib/windows/x86_64 && $(UNZIP) -qjo bassloud24.zip x64/bassloud.dll -d bassloud/lib/windows/x86_64 && \
	$(MKDIR_P) bassloud/include/ && $(UNZIP) -qjo bassloud24.zip c/bassloud.h -d bassloud/include/ && \
	$(MKDIR_P) basswasapi/lib/windows/i686 && $(UNZIP) -qjo basswasapi.zip basswasapi.dll -d basswasapi/lib/windows/i686 && \
	$(MKDIR_P) basswasapi/lib/windows/x86_64 && $(UNZIP) -qjo basswasapi.zip x64/basswasapi.dll -d basswasapi/lib/windows/x86_64 && \
	$(MKDIR_P) basswasapi/include/ && $(UNZIP) -qjo basswasapi24-header.zip c/basswasapi.h -d basswasapi/include/ && \
	$(MKDIR_P) bassasio/lib/windows/i686 && $(UNZIP) -qjo bassasio.zip bassasio.dll -d bassasio/lib/windows/i686 && \
	$(MKDIR_P) bassasio/lib/windows/x86_64 && $(UNZIP) -qjo bassasio.zip x64/bassasio.dll -d bassasio/lib/windows/x86_64 && \
	$(MKDIR_P) bassasio/include/ && $(UNZIP) -qjo bassasio.zip bassasio.h -d bassasio/include/
	touch $@

# linux builds: need linux zips + windows zips for headers (BASS has no aarch64 builds)
$(DEPS_CACHE)/bass-$(BASS_VERSION)-linux.source: $(DEPS_CACHE)/bass-$(BASS_VERSION)/bass24-linux.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassflac24.zip $(DEPS_CACHE)/bass-$(BASS_VERSION)/bassflac24-linux.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bass_fx.zip $(DEPS_CACHE)/bass-$(BASS_VERSION)/bass_fx-linux.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassmix.zip $(DEPS_CACHE)/bass-$(BASS_VERSION)/bassmix-linux.zip $\
										$(DEPS_CACHE)/bass-$(BASS_VERSION)/bassloud24.zip $(DEPS_CACHE)/bass-$(BASS_VERSION)/bassloud24-linux.zip
	cd $(DEPS_CACHE)/bass-$(BASS_VERSION) && \
	$(MKDIR_P) bass/include/ && $(UNZIP) -qjo bass24-linux.zip c/bass.h -d bass/include/ && \
	$(MKDIR_P) bass/lib/linux/i686 && $(UNZIP) -qjo bass24-linux.zip libs/x86/libbass.so -d bass/lib/linux/i686 && \
	$(MKDIR_P) bass/lib/linux/x86_64 && $(UNZIP) -qjo bass24-linux.zip libs/x86_64/libbass.so -d bass/lib/linux/x86_64 && \
	$(MKDIR_P) bassfx/include/ && $(UNZIP) -qjo bass_fx.zip bass_fx.h -d bassfx/include/ && \
	$(MKDIR_P) bassfx/lib/linux/i686 && $(UNZIP) -qjo bass_fx-linux.zip x86/libbass_fx.so -d bassfx/lib/linux/i686 && \
	$(MKDIR_P) bassfx/lib/linux/x86_64 && $(UNZIP) -qjo bass_fx-linux.zip x86_64/libbass_fx.so -d bassfx/lib/linux/x86_64 && \
	$(MKDIR_P) bassflac/lib/linux/i686 && $(UNZIP) -qjo bassflac24-linux.zip libs/x86/libbassflac.so -d bassflac/lib/linux/i686 && \
	$(MKDIR_P) bassflac/lib/linux/x86_64 && $(UNZIP) -qjo bassflac24-linux.zip libs/x86_64/libbassflac.so -d bassflac/lib/linux/x86_64 && \
	$(MKDIR_P) bassmix/include/ && $(UNZIP) -qjo bassmix.zip bassmix.h -d bassmix/include/ && \
	$(MKDIR_P) bassmix/lib/linux/i686 && $(UNZIP) -qjo bassmix-linux.zip x86/libbassmix.so -d bassmix/lib/linux/i686 && \
	$(MKDIR_P) bassmix/lib/linux/x86_64 && $(UNZIP) -qjo bassmix-linux.zip x86_64/libbassmix.so -d bassmix/lib/linux/x86_64 && \
	$(MKDIR_P) bassloud/include/ && $(UNZIP) -qjo bassloud24.zip c/bassloud.h -d bassloud/include/ && \
	$(MKDIR_P) bassloud/lib/linux/i686 && $(UNZIP) -qjo bassloud24-linux.zip libs/x86/libbassloud.so -d bassloud/lib/linux/i686 && \
	$(MKDIR_P) bassloud/lib/linux/x86_64 && $(UNZIP) -qjo bassloud24-linux.zip libs/x86_64/libbassloud.so -d bassloud/lib/linux/x86_64
	touch $@

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/certbundle/cacert.pem:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/certbundle && \
	$(CURLCOMMAND) "https://curl.se/ca/cacert.pem" || { rm -f $@; exit 1; }

# architecture-specific download targets
$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-windowsi686.tar.xz:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	$(CURLCOMMAND) "https://github.com/whrvt/static-curl/releases/download/$(CURL_VERSION_REAL)/curl-windows-i686-dev-$(CURL_VERSION_REAL).tar.xz" || { rm -f $@; exit 1; }

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-windowsx86_64.tar.xz:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	$(CURLCOMMAND) "https://github.com/whrvt/static-curl/releases/download/$(CURL_VERSION_REAL)/curl-windows-x86_64-dev-$(CURL_VERSION_REAL).tar.xz" || { rm -f $@; exit 1; }

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-linuxi686.tar.xz:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	$(CURLCOMMAND) "https://github.com/whrvt/static-curl/releases/download/$(CURL_VERSION_REAL)/curl-linux-i686-dev-$(CURL_VERSION_REAL).tar.xz" || { rm -f $@; exit 1; }

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-linuxx86_64.tar.xz:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	$(CURLCOMMAND) "https://github.com/whrvt/static-curl/releases/download/$(CURL_VERSION_REAL)/curl-linux-x86_64-dev-$(CURL_VERSION_REAL).tar.xz" || { rm -f $@; exit 1; }

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-linuxaarch64.tar.xz:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	$(CURLCOMMAND) "https://github.com/whrvt/static-curl/releases/download/$(CURL_VERSION_REAL)/curl-linux-aarch64-dev-$(CURL_VERSION_REAL).tar.xz" || { rm -f $@; exit 1; }

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-macosaarch64.tar.xz:
	$(MKDIR_P) $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	$(CURLCOMMAND) "https://github.com/stunnel/static-curl/releases/download/$(CURL_VERSION_REAL)/curl-macos-arm64-dev-$(CURL_VERSION_REAL).tar.xz" || { rm -f $@; exit 1; }

# architecture-specific extraction targets
$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-windowsi686.source: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-windowsi686.tar.xz
	cd $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	rm -rf windowsi686 && \
	$(MKDIR_P) windowsi686 && $(TAR) xf curl-windowsi686.tar.xz -C windowsi686 --strip-components=1 --wildcards --no-anchored \
		include lib/'*'.a lib/pkgconfig/'*'ssl'*' lib/pkgconfig/'*'crypto'*' && \
	rm -rf windowsi686/lib/*zlib*.a windowsi686/lib/*libz.*a windowsi686/lib/*brotli*.a
	touch $@

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-windowsx86_64.source: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-windowsx86_64.tar.xz
	cd $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	rm -rf windowsx86_64 && \
	$(MKDIR_P) windowsx86_64 && $(TAR) xf curl-windowsx86_64.tar.xz -C windowsx86_64 --strip-components=1 --wildcards --no-anchored \
		include lib/'*'.a lib64/'*'.a lib64/pkgconfig/'*' && \
	mv windowsx86_64/lib64/* windowsx86_64/lib/ && \
	rm -rf windowsx86_64/lib/*zlib*.a windowsx86_64/lib/*libz.*a windowsx86_64/lib/*brotli*.a
	touch $@

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-linuxi686.source: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-linuxi686.tar.xz
	cd $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	rm -rf linuxi686 && \
	$(MKDIR_P) linuxi686 && $(TAR) xf curl-linuxi686.tar.xz -C linuxi686 --strip-components=1 --wildcards --no-anchored \
		include lib/'*'.a lib/pkgconfig/'*'ssl'*' lib/pkgconfig/'*'crypto'*' && \
	rm -rf linuxi686/lib/libz.a linuxi686/lib/*brotli*.a
	touch $@

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-linuxx86_64.source: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-linuxx86_64.tar.xz
	cd $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	rm -rf linuxx86_64 && \
	$(MKDIR_P) linuxx86_64 && $(TAR) xf curl-linuxx86_64.tar.xz -C linuxx86_64 --strip-components=1 --wildcards --no-anchored \
		include lib/'*'.a lib64/'*'.a lib64/pkgconfig/'*' && \
	mv linuxx86_64/lib64/* linuxx86_64/lib/ && \
	rm -rf linuxx86_64/lib/libz.a linuxx86_64/lib/*brotli*.a
	touch $@

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-linuxaarch64.source: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-linuxaarch64.tar.xz
	cd $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	rm -rf linuxaarch64 && \
	$(MKDIR_P) linuxaarch64 && $(TAR) xf curl-linuxaarch64.tar.xz -C linuxaarch64 --strip-components=1 --wildcards --no-anchored \
		include lib/'*'.a lib/pkgconfig/'*'ssl'*' lib/pkgconfig/'*'crypto'*' && \
	rm -rf linuxaarch64/lib/libz.a linuxaarch64/lib/*brotli*.a
	touch $@

$(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-macosaarch64.source: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/curl-macosaarch64.tar.xz
	cd $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL) && \
	rm -rf macosaarch64 && \
	$(MKDIR_P) macosaarch64 && $(TAR) xf curl-macosaarch64.tar.xz -C macosaarch64 --strip-components=1 --wildcards --no-anchored \
		include lib/'*'.a lib/pkgconfig/'*'ssl'*' lib/pkgconfig/'*'crypto'*' && \
	rm -rf macosaarch64/lib/libz.a macosaarch64/lib/*brotli*.a
	touch $@

#####################################################################################################################################################
#####################################################################################################################################################

#####################################################################################################################################################
#####################################################################################################################################################

# dependencies that aren't built locally (system/prebuilt/disabled) still need their .built
# stamp to exist, since BUILT_SOURCES and inter-dependency prerequisites list them
# unconditionally; this provides a dummy stamp for any dependency without an explicit build
# rule (explicit rules take precedence over pattern rules)
$(DEPS_PREFIX)/%.built:
	$(MKDIR_P) $(DEPS_PREFIX) && touch $@
@BUILD_CURL_TRUE@$(DEPS_PREFIX)/curl-$(CURL_VERSION_REAL).built: $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)-$(SYSNAME)$(host_cpu).source
@BUILD_CURL_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)
@BUILD_CURL_TRUE@	touch $@
@BUILD_MIMALLOC_TRUE@@WIN_PLATFORM_TRUE@$(MIMALLOC_OVERRIDE_DEP): $(DEPS_PREFIX)/mimalloc-$(MIMALLOC_VERSION).built
@BUILD_MIMALLOC_TRUE@@WIN_PLATFORM_TRUE@	@( printf '%s\n%s\n%s' "#include \"mimalloc-new-delete.h\"" "extern \"C\" { __declspec(dllimport) bool mi_redirect_enable(void); }" "void __attribute__((used)) *pmi_redirect_enable = (void*)&mi_redirect_enable;" ) > $(MIMALLOC_OVERRIDE_DEP)
@BUILD_MIMALLOC_TRUE@$(DEPS_PREFIX)/mimalloc-$(MIMALLOC_VERSION).built: $(DEPS_CACHE)/mimalloc-$(MIMALLOC_VERSION).tar.gz $(DEPS_PREFIX)/winpthread-noversion.built
@BUILD_MIMALLOC_TRUE@	rm -rf $(DEPS_PREFIX)/mimalloc
@BUILD_MIMALLOC_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)/mimalloc $(DEPS_PREFIX)/lib && \
@BUILD_MIMALLOC_TRUE@	$(TAR) xf $(DEPS_CACHE)/mimalloc-$(MIMALLOC_VERSION).tar.gz -C $(DEPS_PREFIX)/mimalloc --strip-components=1 && \
@BUILD_MIMALLOC_TRUE@	cd $(DEPS_PREFIX)/mimalloc && \
@BUILD_MIMALLOC_TRUE@	patch -Np1<$(BUILD_MISCDIR)/mimalloc-munlock-before-decommit.patch && \
@BUILD_MIMALLOC_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)/mimalloc/out/"$(if $(ENABLE_DEBUG),debug,release)" && \
@BUILD_MIMALLOC_TRUE@	cd $(DEPS_PREFIX)/mimalloc/out/"$(if $(ENABLE_DEBUG),debug,release)" && \
@BUILD_MIMALLOC_TRUE@	env PKG_CONFIG="$(PKG_CONFIG)" \
@BUILD_MIMALLOC_TRUE@		LDFLAGS="$(LDFLAGS) $(WINPTHREAD_LDFLAGS) -xnone" $(CMAKE_CONF_PFX) $(CMAKE) -S ../.. -B . -G "$(CMAKE_GEN)" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_C_COMPILER="$(CC)" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_C_FLAGS_RELEASE="$(CFLAGS) -Wno-array-bounds" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_C_FLAGS_DEBUG="$(CFLAGS) -Wno-array-bounds" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_CXX_FLAGS_RELEASE="$(CXXFLAGS) -xc++ -Wno-array-bounds" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_CXX_FLAGS_DEBUG="$(CXXFLAGS) -xc++ -Wno-array-bounds" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_SYSTEM_NAME="$(CMAKE_SYSTEM_NAME)" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_SYSTEM_PROCESSOR="$(host_cpu)" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_CXX_COMPILER="$(CXX)" \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_EXPORT_COMPILE_COMMANDS=ON \
@BUILD_MIMALLOC_TRUE@		$(CMAKERCOPT) $(CMAKEIDOPT) \
@BUILD_MIMALLOC_TRUE@		$(CMAKE_AR_RANLIB_FLAGS) \
@BUILD_MIMALLOC_TRUE@		-D CMAKE_INSTALL_PREFIX="$(DEPS_PREFIX)" \
@BUILD_MIMALLOC_TRUE@		-D MI_OPT_ARCH=$(if $(DISABLE_NATIVE),OFF,ON) \
@BUILD_MIMALLOC_TRUE@		-D MI_NO_OPT_ARCH=$(if $(DISABLE_NATIVE),ON,OFF) \
@BUILD_MIMALLOC_TRUE@		-D MI_OPT_SIMD=$(if $(DISABLE_NATIVE),OFF,ON) \
@BUILD_MIMALLOC_TRUE@		-D MI_USE_CXX=ON \
@BUILD_MIMALLOC_TRUE@		-D MI_BUILD_SHARED=ON \
@BUILD_MIMALLOC_TRUE@		-D MI_BUILD_TESTS=OFF \
@BUILD_MIMALLOC_TRUE@		$(if $(filter linux%,$(host_os)),,-DMI_WIN_USE_FIXED_TLS=ON) \
@BUILD_MIMALLOC_TRUE@		$(if $(ENABLE_ASAN),-DMI_LOCAL_DYNAMIC_TLS=ON -DMI_TRACK_ASAN=ON -DMI_DEBUG_UBSAN=ON,) \
@BUILD_MIMALLOC_TRUE@		-D MI_INSTALL_TOPLEVEL=ON \
@BUILD_MIMALLOC_TRUE@		-D MI_BUILD_STATIC=OFF \
@BUILD_MIMALLOC_TRUE@		-D MI_BUILD_OBJECT=ON && \
@BUILD_MIMALLOC_TRUE@	$(CMAKE) --build . "$(CMAKEPAROPT)" && \
@BUILD_MIMALLOC_TRUE@	$(CMAKE) --install .
@BUILD_MIMALLOC_TRUE@	cp $(DEPS_PREFIX)/mimalloc/bin/mimalloc-redirect*.lib $(DEPS_PREFIX)/lib/ || true
@BUILD_MIMALLOC_TRUE@	touch $@
@BUILD_SDL3_TRUE@$(DEPS_PREFIX)/SDL3-$(SDL3_VERSION).built: $(DEPS_CACHE)/SDL3-$(SDL3_VERSION).tar.gz $(DEPS_PREFIX)/freetype-$(FREETYPE2_VERSION).built
@BUILD_SDL3_TRUE@	rm -rf $(DEPS_PREFIX)/SDL3
@BUILD_SDL3_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)/SDL3 $(DEPS_PREFIX)/lib/pkgconfig
@BUILD_SDL3_TRUE@	$(TAR) xf $(DEPS_CACHE)/SDL3-$(SDL3_VERSION).tar.gz -C $(DEPS_PREFIX)/SDL3 --strip-components=1 && \
@BUILD_SDL3_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)/SDL3/build
@BUILD_SDL3_TRUE@	cd $(DEPS_PREFIX)/SDL3 && \
@BUILD_SDL3_TRUE@	$(if $(SDL3_STATIC),$(SED) -i -e 's|#ifdef SDL_DYNAMIC_API.*|#if 1|' -e 's|#error.*Nope.*|#define SDL_DYNAMIC_API 0|' src/dynapi/SDL_dynapi.h,true) && \
@BUILD_SDL3_TRUE@	$(SED) -i 's|KMSDRM_gbm_surface_release_buffer.*next_bo.*|//\0|' src/video/kmsdrm/SDL_kmsdrmvideo.c && \
@BUILD_SDL3_TRUE@	patch -Np1<$(BUILD_MISCDIR)/SDL3-rawinput-improvements.patch && \
@BUILD_SDL3_TRUE@	patch -Np1<$(BUILD_MISCDIR)/SDL3-PR14048-emscripten-clipboard.patch && \
@BUILD_SDL3_TRUE@	patch -Np1<$(BUILD_MISCDIR)/SDL3-WIP-gpu_vulkan-Address-more-defragmentation-related-.patch && \
@BUILD_SDL3_TRUE@	patch -Np1<$(BUILD_MISCDIR)/SDL3-IS15656-D3D12-latency-poc.patch && \
@BUILD_SDL3_TRUE@	PKG_CONFIG="$(PKG_CONFIG)" LDFLAGS="$(LDFLAGS) $(if $(SDL3_STATIC),,$(SDL3_EXTRALIBS))" CC="$(CC)" CXX="$(CXX)" \
@BUILD_SDL3_TRUE@	$(CMAKE_CONF_PFX) $(CMAKE) -S . -B build -G "$(CMAKE_GEN)" \
@BUILD_SDL3_TRUE@		-D CMAKE_BUILD_TYPE="$(if $(ENABLE_DEBUG),Debug,Release)" \
@BUILD_SDL3_TRUE@		$(if $(ENABLE_ASAN),-DSDL_ASAN=ON,) \
@BUILD_SDL3_TRUE@		-D SDL_HIDAPI_LIBUSB=OFF \
@BUILD_SDL3_TRUE@		-D CMAKE_INSTALL_PREFIX="$(DEPS_PREFIX)" \
@BUILD_SDL3_TRUE@		-D SDL_SHARED="$(if $(SDL3_STATIC),OFF,ON)" \
@BUILD_SDL3_TRUE@		-D SDL_STATIC="$(if $(SDL3_STATIC),ON,OFF)" \
@BUILD_SDL3_TRUE@		-D CMAKE_SYSTEM_NAME="$(CMAKE_SYSTEM_NAME)" \
@BUILD_SDL3_TRUE@		-D CMAKE_EXPORT_COMPILE_COMMANDS=ON \
@BUILD_SDL3_TRUE@		$(CMAKERCOPT) $(CMAKEIDOPT) \
@BUILD_SDL3_TRUE@		$(CMAKE_AR_RANLIB_FLAGS) \
@BUILD_SDL3_TRUE@		-D CMAKE_SYSTEM_PROCESSOR="$(host_cpu)" \
@BUILD_SDL3_TRUE@		$(if $(WASM_CC),-DSDL_PTHREADS=ON,) \
@BUILD_SDL3_TRUE@		-D SDL_RPATH=OFF \
@BUILD_SDL3_TRUE@		-D SDL_IBUS=OFF \
@BUILD_SDL3_TRUE@		-D SDL_TEST_LIBRARY=OFF \
@BUILD_SDL3_TRUE@		-D SDL_JOYSTICK=OFF \
@BUILD_SDL3_TRUE@		-D SDL_CAMERA=OFF \
@BUILD_SDL3_TRUE@		-D SDL_GPU=ON \
@BUILD_SDL3_TRUE@		-D SDL_HAPTIC=OFF \
@BUILD_SDL3_TRUE@		-D SDL_SENSOR=OFF \
@BUILD_SDL3_TRUE@		-D SDL_DUMMYAUDIO=ON \
@BUILD_SDL3_TRUE@		-D SDL_DUMMYCAMERA=OFF \
@BUILD_SDL3_TRUE@		-D SDL_DUMMYVIDEO=ON \
@BUILD_SDL3_TRUE@		-D SDL_OFFSCREEN=ON \
@BUILD_SDL3_TRUE@		-D SDL_RENDER_GPU=OFF \
@BUILD_SDL3_TRUE@		-D SDL_RENDER_VULKAN=OFF \
@BUILD_SDL3_TRUE@		-D SDL_RENDER=OFF \
@BUILD_SDL3_TRUE@		-D SDL_CAMERA=OFF \
@BUILD_SDL3_TRUE@		-D SDL_HIDAPI=OFF \
@BUILD_SDL3_TRUE@		-D SDL_VIRTUAL_JOYSTICK=OFF \
@BUILD_SDL3_TRUE@		$(if $(NOIME),-DSDL_DBUS=OFF -DSDL_USE_IME=OFF -DSDL_DISABLE_WINDOWS_IME=ON,) \
@BUILD_SDL3_TRUE@		-D SDL_CCACHE="$(if $(filter ccache,$(CCACHE)),ON,OFF)" \
@BUILD_SDL3_TRUE@		-D CMAKE_C_COMPILER="$(CC)" \
@BUILD_SDL3_TRUE@		-D CMAKE_C_FLAGS_RELEASE="$(CFLAGS) -Wno-error=incompatible-pointer-types -DUSE_XINPUT2_KEYBOARD=1" \
@BUILD_SDL3_TRUE@		-D CMAKE_C_FLAGS_DEBUG="$(CFLAGS) -Wno-error=incompatible-pointer-types -DUSE_XINPUT2_KEYBOARD=1" && \
@BUILD_SDL3_TRUE@	$(CMAKE) --build build "$(CMAKEPAROPT)" && \
@BUILD_SDL3_TRUE@	$(CMAKE) --install build
@BUILD_SDL3_TRUE@	$(PKG_CONFIG) --exists --print-errors sdl3
@BUILD_SDL3_TRUE@	touch $@
@BUILD_MPG123_TRUE@$(DEPS_PREFIX)/mpg123-$(MPG123_VERSION).built: $(DEPS_CACHE)/mpg123-$(MPG123_VERSION).tar.gz
@BUILD_MPG123_TRUE@	rm -rf $(DEPS_PREFIX)/mpg123
@BUILD_MPG123_TRUE@	$(MKDIR_P) $(DEPS_PREFIX) $(DEPS_PREFIX)/include $(DEPS_PREFIX)/lib/pkgconfig $(DEPS_PREFIX)/mpg123/build
@BUILD_MPG123_TRUE@	$(TAR) xf $(DEPS_CACHE)/mpg123-$(MPG123_VERSION).tar.gz -C $(DEPS_PREFIX)/mpg123 --strip-components=1 && \
