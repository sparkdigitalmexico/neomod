@BUILD_CTRE_TRUE@		-D CMAKE_CXX_FLAGS_DEBUG="$(CXXFLAGS)" \
@BUILD_CTRE_TRUE@		-D CTRE_BUILD_TESTS=OFF \
@BUILD_CTRE_TRUE@		-D CTRE_BUILD_PACKAGE=ON \
@BUILD_CTRE_TRUE@		-D CTRE_BUILD_PACKAGE_DEB=OFF \
@BUILD_CTRE_TRUE@		-D CTRE_BUILD_PACKAGE_RPM=OFF && \
@BUILD_CTRE_TRUE@	$(CMAKE) --build build "$(CMAKEPAROPT)" && \
@BUILD_CTRE_TRUE@	$(CMAKE) --install build
@BUILD_CTRE_TRUE@	$(PKG_CONFIG) --exists --print-errors ctre
@BUILD_CTRE_TRUE@	touch $@
