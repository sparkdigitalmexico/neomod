# neomod.pot file is the main translation template
# .po files contain translations for each language
# .mo files are compiled translations
# locale_embed.manifest is used to embed the .mo files
# translations.h contains english strings & the language list
@ENABLE_I18N_TRUE@PO_FILES := $(wildcard $(srcdir)/translations/*.po)
@ENABLE_I18N_FALSE@MO_FILES := 
@ENABLE_I18N_TRUE@MO_FILES := $(patsubst $(srcdir)/translations/%.po, $(builddir)/gen/%.mo, $(PO_FILES))
# NOTE: non-recursive (:=) so won't pick up anything added to neomod_SOURCES after this point,
# but translatable strings only exist in sources that are already in it at this point so it shouldn't matter in practice
@ENABLE_I18N_TRUE@TRANSLATION_SRCS := $(filter-out $(EMBED_OUTPUT),$(filter %.cpp,$(neomod_SOURCES)))
@ENABLE_I18N_TRUE@TRANSLATION_SCRIPT := $(srcdir)/build-aux/gen_translations.py
@ENABLE_I18N_FALSE@GEN_TRANSLATIONS_STAMP := 

# gen_translations.py is the sole producer of the translation outputs: it runs xgettext
# + msgmerge + msgattrib + msgfmt internally with cmp-and-write semantics, producing
# .pot, .po, .mo, translations.h, and locale_embed.manifest in one shot. PO_FILES are
# listed as prereqs so manual translator edits (e.g. fixing fr.po by hand) trigger regen.
@ENABLE_I18N_TRUE@GEN_TRANSLATIONS_STAMP := $(builddir)/gen/.translations.stamp
@ENABLE_I18N_FALSE@TRANSLATIONS_HEADER := 
@ENABLE_I18N_TRUE@TRANSLATIONS_HEADER := $(builddir)/gen/translations.h
@ENABLE_I18N_FALSE@TRANSLATIONS_LOCALE_MANIFEST := 
@ENABLE_I18N_TRUE@TRANSLATIONS_LOCALE_MANIFEST := $(builddir)/gen/locale_embed.manifest

