@WASM_PLATFORM_FALSE@EMBED_CACERT_DEPS := $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/certbundle/cacert.pem

# cacert.pem is only needed on non-WASM platforms (WASM uses browser TLS, not curl)
