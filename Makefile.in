@BUILD_FREETYPE2_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(FREETYPE2_PREFIX) -not -path '*.dSYM/*' '(' -iname '*freetype*'$(DLLEXT) -o -iname '*freetype*''.so.*' ')' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@BUILD_FMT_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(FMT_PREFIX) -not -path '*.dSYM/*' '(' -iname '*fmt*'$(DLLEXT) -o -iname '*fmt*''.so.*' ')' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@BUILD_NSYNC_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(NSYNC_PREFIX) -not -path '*.dSYM/*' '(' -iname '*nsync*'$(DLLEXT) -o -iname '*nsync*''.so.*' ')' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@BUILD_LZMA_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(LZMA_PREFIX) -not -path '*.dSYM/*' '(' -iname '*lzma*'$(DLLEXT) -o -iname '*lzma*''.so.*' ')' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@BUILD_SIMDUTF_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(SIMDUTF_PREFIX) -not -path '*.dSYM/*' '(' -iname '*simdutf*'$(DLLEXT) -o -iname '*simdutf*''.so.*' ')' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@BUILD_LIBARCHIVE_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(LIBARCHIVE_PREFIX) -not -path '*.dSYM/*' '(' -iname '*archive*'$(DLLEXT) -o -iname '*archive*''.so.*' ')' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@BUILD_LIBACL_TRUE@@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@`find $(LIBACL_PREFIX) -iname '*acl*''.so.*' -exec $(CP_INSTALL) '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)" ';'`)
@WASM_PLATFORM_FALSE@	@# copy the .dSYM bundles already during dependency builds (TODO: some are missing, like cmake-based builds and ffmpeg)
@WASM_PLATFORM_FALSE@	$(if $(STATICBUILD),,@find $(DEPS_PREFIX) -name '*$(DLLEXT).dSYM' -type d -prune -exec $(CP_INSTALL) -R '{''}' "$(DESTDIR)$(bindir)/$(LIBDEST)/" ';' 2>/dev/null || true)
@WASM_PLATFORM_FALSE@	@touch $@

# --- patchelf rpath (linux only) ---
@LINUX_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@stamp-install-rpath: stamp-install-sharedlibs
@LINUX_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	find "$(DESTDIR)$(bindir)/lib" -maxdepth 1 -name '*'.so'*' -execdir $(PATCHELF) --set-rpath '$$ORIGIN:$$ORIGIN/../' '{''}' ';'
@LINUX_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	find "$(DESTDIR)$(bindir)" -maxdepth 1 -name '*'.so'*' -execdir $(PATCHELF) --set-rpath '$$ORIGIN:$$ORIGIN/lib' '{''}' ';'
@LINUX_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	@touch $@

# --- install_name_tool rpath (macos only) ---
# rewrite absolute build-time install names to @loader_path so dylibs resolve
# their dependencies from the directory they were installed to, not the build tree.
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@stamp-install-librpath: stamp-install-sharedlibs
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	@for dir in "$(DESTDIR)$(bindir)" "$(DESTDIR)$(bindir)/lib"; do \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		test -d "$$dir" || continue; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		find "$$dir" -maxdepth 1 -name '*.dylib' | while read -r lib; do \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@			args="-id @loader_path/$$(basename "$$lib")"; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@			for dep in $$(otool -L "$$lib" | $(SED) -n 's/^[[:space:]]*\([^[:space:]]*\).*/\1/p'); do \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@				depbn=$$(basename "$$dep"); \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@				test -f "$$dir/$$depbn" && args="$$args -change $$dep @loader_path/$$depbn"; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@			done; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@			$(INSTALL_NAME_TOOL) $$args "$$lib" 2>/dev/null || true; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		done; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	done
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	@touch $@

@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@stamp-install-exerpath: stamp-install-sharedlibs $(bin_PROGRAMS)
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	@for prog in $(bin_PROGRAMS); do \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		test -f "$(DESTDIR)$(bindir)/$$prog" || continue; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		args=""; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		for dep in $$(otool -L "$(DESTDIR)$(bindir)/$$prog" | $(SED) -n 's/^[[:space:]]*\([^[:space:]]*\).*/\1/p'); do \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@			depbn=$$(basename "$$dep"); \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@			test -f "$(DESTDIR)$(bindir)/lib/$$depbn" && args="$$args -change $$dep @rpath/$$depbn"; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		done; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@		test -n "$$args" && $(INSTALL_NAME_TOOL) $$args "$(DESTDIR)$(bindir)/$$prog" 2>/dev/null || true; \
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	done
@MACOS_PLATFORM_TRUE@@WASM_PLATFORM_FALSE@	@touch $@

# --- generate .dSYM bundle (macos only, when debug info is present) ---
# without this, sanitizer/lldb/atos backtraces only show binary offsets,
# since debug info on mach-o stays in the .o files until dsymutil collects it.
@RUN_DSYMUTIL_TRUE@@WASM_PLATFORM_FALSE@stamp-install-dsym: stamp-install-sharedlibs $(INSTALL_RPATH_STAMP) $(bin_PROGRAMS)
@RUN_DSYMUTIL_TRUE@@WASM_PLATFORM_FALSE@	$(DSYMUTIL) -j $(CPU_COUNT) --linker parallel "$(DESTDIR)$(bindir)/$(bin_PROGRAMS)"
@RUN_DSYMUTIL_TRUE@@WASM_PLATFORM_FALSE@	@touch $@
@STRIPBINS_TRUE@@WASM_PLATFORM_FALSE@stamp-install-strip: stamp-install-sharedlibs $(INSTALL_RPATH_STAMP) $(bin_PROGRAMS) $(DSYM_PRE_STRIP_DEP)
@STRIPBINS_TRUE@@WASM_PLATFORM_FALSE@	-find "$(DESTDIR)$(bindir)" -name '*'$(DLLEXT)'*' -execdir $(STRIP) $(STRIP_ALL_FLAGS) '{''}' '+'
@STRIPBINS_TRUE@@WASM_PLATFORM_FALSE@	-$(STRIP) $(STRIP_ALL_FLAGS) "$(DESTDIR)$(bindir)/$(bin_PROGRAMS)"
@STRIPBINS_TRUE@@WASM_PLATFORM_FALSE@	@touch $@

# --- wine audio backend shortcuts (windows cross-compile only) ---
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@stamp-install-wine-shortcuts: | install-dirs
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@	@cd "$(DESTDIR)$(bindir)" && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@	for backend in $(AUDBACKENDLIST); do \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo 'Set WshShell = CreateObject("WScript.Shell")' > temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo "Set Shortcut = WshShell.CreateShortcut(\"neomod-$$backend.lnk\")" >> temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo 'Shortcut.TargetPath = "C:\Windows\System32\cmd.exe"' >> temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo "Shortcut.Arguments = \"/c start \"\"\"\" \"\".\\$(PROGRAMS)\"\" -sound $$backend\"" >> temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo "Shortcut.Description = \"neomod with the $$backend audio backend\"" >> temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo 'Shortcut.WindowStyle = 7' >> temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		echo 'Shortcut.Save' >> temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		WINEPREFIX=$(TEMP_WINEPFX) DISPLAY= WAYLAND_DISPLAY= WINEDLLOVERRIDES="mscoree=;mshtml=;winex11.drv=;winewayland.drv=" WINEDEBUG=-all \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		$(WINE) cscript temp.vbs && \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@		rm temp.vbs; \
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@	done
@AUDIO_SHORTCUTS_TRUE@@WASM_PLATFORM_FALSE@	@touch $@

# --- invalidate stamps if the install dir was recreated (new device:inode) ---
@WASM_PLATFORM_FALSE@.install-state: FORCE
@WASM_PLATFORM_FALSE@	@new=$$(stat -c '%d:%i' "$(DESTDIR)$(bindir)" 2>/dev/null || stat -f '%d:%i' "$(DESTDIR)$(bindir)" 2>/dev/null || echo none); \
@WASM_PLATFORM_FALSE@	old=$$(cat $@ 2>/dev/null || echo ""); \
@WASM_PLATFORM_FALSE@	if [ "$$old" != "$$new" ]; then \
@WASM_PLATFORM_FALSE@		rm -f $(INSTALL_STAMPS); \
@WASM_PLATFORM_FALSE@		printf '%s' "$$new" > $@; \
@WASM_PLATFORM_FALSE@	fi
@WASM_PLATFORM_FALSE@$(INSTALL_STAMPS): .install-state

# --- wire it all together ---
@WASM_PLATFORM_FALSE@install-libs: install-dirs $(INSTALL_STAMPS)

# install hooks
# copy pdb (windows), create app bundle (macos)
install-exec-hook: install-libs
@WIN_PLATFORM_TRUE@	@cp -P neomod.pdb "$(DESTDIR)$(bindir)" &>/dev/null || true # don't fail install if we had no pdb
@MACOS_PLATFORM_TRUE@	@echo "  BUNDLE neomod.app"
@MACOS_PLATFORM_TRUE@	@$(MKDIR_P) "$(DESTDIR)$(prefix)/neomod.app/Contents/Resources"
@MACOS_PLATFORM_TRUE@	@printf 'APPL????' > "$(DESTDIR)$(prefix)/neomod.app/Contents/PkgInfo"
@MACOS_PLATFORM_TRUE@	@$(SED) 's/%%VERSION%%/$(PACKAGE_VERSION)/g' \
@MACOS_PLATFORM_TRUE@		"$(srcdir)/assets/Info.plist.in" > "$(DESTDIR)$(prefix)/neomod.app/Contents/Info.plist"
@MACOS_PLATFORM_TRUE@	@cp "$(srcdir)/assets/neomod.icns" \
@MACOS_PLATFORM_TRUE@		"$(DESTDIR)$(prefix)/neomod.app/Contents/Resources/neomod.icns"
@MACOS_PLATFORM_TRUE@	@ln -sfn "neomod.app/Contents/MacOS" "$(DESTDIR)$(prefix)/bin-$(host_cpu)"

uninstall-local:
@MACOS_PLATFORM_TRUE@	rm -rf "$(DESTDIR)$(prefix)/neomod.app/" "$(DESTDIR)$(prefix)/bin-$(host_cpu)"
@MACOS_PLATFORM_FALSE@	rm -rf "$(DESTDIR)$(bindir)/"
	-rm -f $(INSTALL_STAMPS) .install-state

# cleanup targets
clean-local:
	rm -rf $(builddir)/build/obj
	rm -f $(PROGRAMS)

clean-deps:
	rm -rf $(DEPS_PREFIX) && $(MKDIR_P) $(DEPS_PREFIX)

clean-dep-cache:
	rm -rf $(DEPS_CACHE)
.PHONY: clean-deps clean-dep-cache install-libs install-dirs bear-check-version FORCE

maintainer-clean-local: clean-deps clean-dep-cache

distclean-local: clean-deps clean-dep-cache

# TODO: distribution packaging
dist-hook:
	cp -r $(srcdir)/$(ASSETS_DIR)/fonts $(distdir)/
	cp -r $(srcdir)/$(ASSETS_DIR)/materials $(distdir)/
	find $(distdir) -type f -name ".git*" -delete
	find $(distdir) -type f -name "*.a" -delete
	find $(distdir) -type f -name "*.dll" -delete
	find $(distdir) -type f -name "*.dylib" -delete

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:

# Tell GNU make to disable its built-in pattern rules.
%:: %,v
%:: RCS/%,v
%:: RCS/%
%:: s.%
%:: SCCS/s.%
