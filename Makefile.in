@BUILD_WINPTHREAD_NOVERSION_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)/lib
@BUILD_WINPTHREAD_NOVERSION_TRUE@	cp "$(WINPTHREAD_ORIG)" $(DEPS_PREFIX)/lib/libwinpthread_noversion.a
@BUILD_WINPTHREAD_NOVERSION_TRUE@	$(AR) -d $(DEPS_PREFIX)/lib/libwinpthread_noversion.a version.o
@BUILD_WINPTHREAD_NOVERSION_TRUE@	touch $@

@ENABLE_I18N_TRUE@$(GEN_TRANSLATIONS_STAMP): $(TRANSLATION_SCRIPT) $(TRANSLATION_SRCS) $(PO_FILES)
@ENABLE_I18N_TRUE@	@$(MKDIR_P) $(dir $@)
@ENABLE_I18N_TRUE@	$(PYTHON) $(TRANSLATION_SCRIPT) $(srcdir) $(builddir)
@ENABLE_I18N_TRUE@	@touch $@

@ENABLE_I18N_TRUE@$(builddir)/gen/%.mo: $(GEN_TRANSLATIONS_STAMP) ;
@ENABLE_I18N_TRUE@$(TRANSLATIONS_HEADER): $(GEN_TRANSLATIONS_STAMP) ;
@ENABLE_I18N_TRUE@$(TRANSLATIONS_LOCALE_MANIFEST): $(GEN_TRANSLATIONS_STAMP) ;
@DOWNLOAD_DXC_TRUE@@USE_SDLGPU_TRUE@$(DEPS_CACHE)/linux_dxc_2025_07_14.x86_64.source: $(DEPS_CACHE)/linux_dxc_2025_07_14.x86_64.tar.gz
@DOWNLOAD_DXC_TRUE@@USE_SDLGPU_TRUE@	$(MKDIR_P) $(DEPS_CACHE)/linux_dxc_2025_07_14 && \
@DOWNLOAD_DXC_TRUE@@USE_SDLGPU_TRUE@	$(TAR) xf $(DEPS_CACHE)/linux_dxc_2025_07_14.x86_64.tar.gz -C $(DEPS_CACHE)/linux_dxc_2025_07_14 --strip-components=1 && \
@DOWNLOAD_DXC_TRUE@@USE_SDLGPU_TRUE@	test -f $(DEPS_CACHE)/linux_dxc_2025_07_14/bin/dxc && \
@DOWNLOAD_DXC_TRUE@@USE_SDLGPU_TRUE@	touch $@

# the manifest is the natural "stamp". pack_sdlgpu_shader.py always writes it,
# so its mtime reflects when shaders were last compiled/packed
@USE_SDLGPU_TRUE@$(SDLGPU_SHADER_MANIFEST): $(SDLGPU_DXC_DEP) $(SDLGPU_GLSL_INPUTS) $(SDLGPU_HLSL_INPUTS) $(SDLGPU_MSL_INPUTS) $(SDLGPU_PACK_SCRIPT)
@USE_SDLGPU_TRUE@	$(MKDIR_P) $(SDLGPU_SHADER_DIR)
@USE_SDLGPU_TRUE@	$(PYTHON) $(SDLGPU_PACK_SCRIPT) \
@USE_SDLGPU_TRUE@		--shader-dir $(srcdir)/$(ASSETS_DIR)/shaders \
@USE_SDLGPU_TRUE@		--output-dir $(SDLGPU_SHADER_DIR) \
@USE_SDLGPU_TRUE@		--manifest $(SDLGPU_SHADER_MANIFEST) \
@USE_SDLGPU_TRUE@		$(SDLGPU_GLSLC_FLAG) \
@USE_SDLGPU_TRUE@		$(SDLGPU_DXC_FLAG)

# individual .shdpk files are side effects of the manifest rule;
# the depfile lists them, so make needs to know how to "build" them
@USE_SDLGPU_TRUE@$(SDLGPU_SHADER_DIR)/%.shdpk: $(SDLGPU_SHADER_MANIFEST) ;
$(EMBED_CONFIG_STAMP): FORCE
	@$(MKDIR_P) $(dir $@)
	@echo '$(EMBED_FULL_MANIFEST_FLAGS)' | cmp -s - $@ || echo '$(EMBED_FULL_MANIFEST_FLAGS)' > $@

$(EMBED_OUTPUT): $(EMBED_SCRIPT) $(EMBED_MANIFESTS) $(BUILD_EMBED_MANIFESTS) $(EMBED_CACERT_DEPS) $(SDLGPU_EMBED_DEPS) $(EMBED_CONFIG_STAMP) $(MO_FILES)
	$(MKDIR_P) $(dir $@)
	$(PYTHON) $(EMBED_SCRIPT) -t $(EMBED_TYPE) -b $(srcdir) -d $(EMBED_DEPFILE) $(EMBED_FULL_MANIFEST_FLAGS) $@ \
		$(EMBED_CACERT_ARGS)

-include $(EMBED_DEPFILE)

@BUILD_PCH_TRUE@$(PCH_OUTPUT): $(PCH_SOURCE) $(BUILT_SOURCES)
@BUILD_PCH_TRUE@	@rm -f $(PCH_OUTPUT) # remove possibly existing-but-outdated pch to avoid recursively including it (sanity)
@BUILD_PCH_TRUE@	@$(MKDIR_P) $(dir $@)
@BUILD_PCH_TRUE@	$(CXX) -x c++-header -MMD -MF $(PCH_DEPS) $(PCH_BUILD_FLAGS) \
@BUILD_PCH_TRUE@		$(CPPFLAGS) $(neomod_CPPFLAGS) $(neomod_CXXFLAGS) $(CXXFLAGS) \
@BUILD_PCH_TRUE@		-o $@ $(PCH_SOURCE)

@BUILD_PCH_TRUE@-include $(PCH_DEPS)

# making sure deps are built before main compile
# EMBED_OUTPUT is order-only (after |): must exist before compilation, but updating it doesn't rebuild all objects
# (only binary_embed.o through neomod_SOURCES dep)
# translations.h is also order-only: only the ~20 TUs that explicitly `#include "i18n.h"` actually
# depend on it (the per-source .d files track this). Keeping it order-only means a translatable-string
# add/remove doesn't churn the whole tree; non-translation TUs sail through unchanged.
$(neomod_OBJECTS): $(BUILT_SOURCES) $(PCH_OUTPUT) | $(EMBED_OUTPUT) $(TRANSLATIONS_HEADER)

# windows icon/resource things
@WIN_PLATFORM_TRUE@neomod_resource.o: $(srcdir)/$(ASSETS_DIR)/resource.rc $(srcdir)/$(ASSETS_DIR)/neomod.manifest $(srcdir)/$(ASSETS_DIR)/icon.ico
@WIN_PLATFORM_TRUE@	$(WINDRES) -I $(srcdir)/$(ASSETS_DIR) -i $(srcdir)/$(ASSETS_DIR)/resource.rc -o neomod_resource.o

# bear doesn't work on macos, so use clang's -MJ flag instead (emits compile_commands fragments) and concatenate them at the end
@MACOS_PLATFORM_TRUE@compile_commands.json: mostlyclean-compile
@MACOS_PLATFORM_TRUE@	$(MAKE_PFX) $(MAKE) $(AM_MAKEFLAGS) $(BUILT_SOURCES) && \
@MACOS_PLATFORM_TRUE@	$(MAKE_PFX) $(MAKE) $(AM_MAKEFLAGS) 'CFLAGS=$(CFLAGS) -MJ$$@.compdb' 'CXXFLAGS=$(CXXFLAGS) -MJ$$@.compdb' $(neomod_OBJECTS) $(neomod_DEPENDENCIES) $(EXTRA_neomod_DEPENDENCIES) && \
@MACOS_PLATFORM_TRUE@	$(PYTHON) $(srcdir)/build-aux/gen_compdb.py --strip-pch --delete -o $@ .
@MACOS_PLATFORM_FALSE@bear-check-version:
@MACOS_PLATFORM_FALSE@	@$(BEAR) --version || { echo bear is unavailable to generate a compile_commands.json, install bear && exit 1; }
@MACOS_PLATFORM_FALSE@	@if [ `$(BEAR) --version | cut -d' ' -f2 | cut -d'.' -f1` -ge 4 ]; then { \
@MACOS_PLATFORM_FALSE@	  echo "bear 4.0 support is broken, downgrade to bear 3.x" && exit 1; \
@MACOS_PLATFORM_FALSE@	}; else { \
@MACOS_PLATFORM_FALSE@	  exit 0; \
@MACOS_PLATFORM_FALSE@	}; fi

@MACOS_PLATFORM_FALSE@bear.cfg: bear-check-version
@MACOS_PLATFORM_FALSE@	@(echo '{'; \
@MACOS_PLATFORM_FALSE@	  echo '"compilation": {'; \
@MACOS_PLATFORM_FALSE@	  echo '"compilers_to_recognize": ['; \
@MACOS_PLATFORM_FALSE@	  echo '{'; \
@MACOS_PLATFORM_FALSE@	  echo '"executable": "emcc"'; \
@MACOS_PLATFORM_FALSE@	  echo '},'; \
@MACOS_PLATFORM_FALSE@	  echo '{'; \
@MACOS_PLATFORM_FALSE@	  echo '"executable": "em++"'; \
@MACOS_PLATFORM_FALSE@	  echo '},'; \
@MACOS_PLATFORM_FALSE@	  echo '{'; \
@MACOS_PLATFORM_FALSE@	  echo '"executable": "$(CC_REAL)"'; \
@MACOS_PLATFORM_FALSE@	  echo '},'; \
@MACOS_PLATFORM_FALSE@	  echo '{'; \
@MACOS_PLATFORM_FALSE@	  echo '"executable": "$(CXX_REAL)"'; \
@MACOS_PLATFORM_FALSE@	  echo '}'; \
@MACOS_PLATFORM_FALSE@	  echo '],'; \
@MACOS_PLATFORM_FALSE@	  echo '"compilers_to_exclude": ["$(CXX)", "$(CC)"]'; \
@MACOS_PLATFORM_FALSE@	  echo '}'; \
@MACOS_PLATFORM_FALSE@	  echo '}' ) > bear.cfg

# bear 4.0 is BROKEN and i have no idea what the hell it wants
# this is what i had for future reference when it becomes unbroken
#	  echo 'schema: "4.0"'; \
#	  echo 'compilers:'; \
#	  echo '  - path: $(CXX)'; \
#	  echo '    ignore: true'; \
#	  echo '  - path: $(CC)'; \
#	  echo '    ignore: true'; \
#	  echo '  - path: $(CXX_REAL)'; \
#	  echo '    ignore: false'; \
#	  echo '    as: $(if $(findstring yes,$(CLANG)),clang,gcc)'; \
#	  echo '  - path: $(CC_REAL)'; \
#	  echo '    ignore: false'; \
#	  echo '    as: $(if $(findstring yes,$(CLANG)),clang,gcc)' ; } > bear.cfg; fi

# need to manually make sure BUILT_SOURCES (dependencies) are fully built before building the main neomod objects, due to weird
# interactions with sub-makes and parallel jobs
# also run an extra step to exclude PCH flags
# this is so that you avoid missing includes when it's already in the PCH and clangd then thinks it's already included
@MACOS_PLATFORM_FALSE@compile_commands.json: bear.cfg mostlyclean-compile
@MACOS_PLATFORM_FALSE@	$(BEAR) --config bear.cfg --append -- $(MAKE_PFX) $(MAKE) $(AM_MAKEFLAGS) $(BUILT_SOURCES) && \
@MACOS_PLATFORM_FALSE@	$(BEAR) --config bear.cfg --append -- $(MAKE_PFX) $(MAKE) $(AM_MAKEFLAGS) $(neomod_OBJECTS) $(neomod_DEPENDENCIES) $(EXTRA_neomod_DEPENDENCIES) && \
@MACOS_PLATFORM_FALSE@	$(SED) -i '/"-include",/{N;/"\.\/pch\.h",/d;}' $@

$(abs_top_srcdir)/.clangd: compile_commands.json
	@if [ -f $@ ]; then { \
		if $(GREP) -q "CompilationDatabase:" $@; then { \
			$(SED) -i 's|CompilationDatabase:.*|CompilationDatabase: $(shell $(REALPATH) --relative-to=$(abs_top_srcdir) $(CURDIR))|g' $@; \
		}; else { \
			echo "CompileFlags:" >> $@; \
			echo "    CompilationDatabase: $(shell $(REALPATH) --relative-to=$(abs_top_srcdir) $(CURDIR))" >> $@; \
		}; fi; \
	}; else { \
		echo "CompileFlags:" > $@; \
		echo "    Add: [-D_CLANGD]" >> $@; \
		echo "    BuiltinHeaders: QueryDriver" >> $@; \
		echo "    CompilationDatabase: $(shell $(REALPATH) --relative-to=$(abs_top_srcdir) $(CURDIR))" >> $@; \
		echo "" >> $@; \
		echo "InlayHints:" >> $@; \
		echo "    Enabled: No" >> $@; \
	}; fi

# `make compile-commands` to generate a compile_commands.json database
compile-commands: $(abs_top_srcdir)/.clangd

