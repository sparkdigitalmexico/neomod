#####################################################################################################################################################
#####################################################################################################################################################

# SOURCE (to-build) dependencies (conditionally downloaded depending on build configuration)
CURLCOMMAND = $(CURLBIN) -fsSLo $@ --retry 3 --retry-delay 5 --retry-all-errors --connect-timeout 30 --max-time 300

# --with-ffmpeg
# if changing build params, to invalidate .built stamps (without updating version)
FFMPEG_EPOCH := 5
# newer releases are broken for windows xp
FFMPEG_VERSION_REAL := $(if $(ubercompat),2456a39581c3388bcf6f61c66aef36a887537c23,$(FFMPEG_VERSION))
FFMPEG_URL := $(if $(ubercompat),https://github.com/FFmpeg/FFmpeg/archive/$(FFMPEG_VERSION_REAL).tar.gz,https://ffmpeg.org/releases/ffmpeg-$(FFMPEG_VERSION_REAL).tar.xz)
FFMPEG_TARBALL := $(if $(ubercompat),ffmpeg-$(FFMPEG_VERSION_REAL).tar.gz,ffmpeg-$(FFMPEG_VERSION_REAL).tar.xz)

# TEMPTEMP: beatmap pack for WASM demo (pre-extracted)
# this is going through the "osu! stable raw load" path for database loading,
# for some reason we still only have raw loading of .osz files for neomod_maps (TODO)
WASM_BEATMAP_PACK_URL := "https://packs.ppy.sh/S1757%20-%20osu%21%20Beatmap%20Pack%20%231757.zip"
EXTRACTED_MAPS_DEP := $(am__append_1)

# NOTE: curl 8.18.0 is the last version that supported windows XP, so we use that for windows 32bit compat builds
CURL_VERSION_REAL := $(if $(ubercompat),8.18.0,$(CURL_VERSION))

# macos/darwin isn't gnu-ld
# TODO: support/compatibility for this should be checked in configure!
LT_GNU_LD_CACHE := $(if $(filter darwin%,$(host_os)),,lt_cv_prog_gnu_ld=yes)
LT_WITH_GNU_LD := $(if $(filter darwin%,$(host_os)),,--with-gnu-ld)
CACERT_INCDIR := $(DEPS_CACHE)/curl-$(CURL_VERSION_REAL)/certbundle/
PKG_CONFIG_PLUS_BUNDLED_OSSL = $(PKG_CONFIG) $(am__append_4)
@BUILD_CURL_TRUE@lb := (
@BUILD_CURL_TRUE@lbq := '('
@BUILD_CURL_TRUE@rb := )
@BUILD_CURL_TRUE@rbq := ')'

# use prebuilt binaries
