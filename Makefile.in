@BUILD_LIBARCHIVE_TRUE@$(DEPS_PREFIX)/libarchive-$(LIBARCHIVE_VERSION).built: $(DEPS_CACHE)/libarchive-$(LIBARCHIVE_VERSION).tar.gz $(DEPS_PREFIX)/curl-$(CURL_VERSION_REAL).built \
@BUILD_LIBARCHIVE_TRUE@											$(DEPS_PREFIX)/libacl-$(LIBACL_VERSION).built $(DEPS_PREFIX)/liblzma-$(LZMA_VERSION).built \
@BUILD_LIBARCHIVE_TRUE@											$(DEPS_PREFIX)/bzip2-$(BZIP2_VERSION).built $(DEPS_PREFIX)/zlib-$(ZLIB_VERSION).built
@BUILD_LIBARCHIVE_TRUE@	rm -rf $(DEPS_PREFIX)/libarchive
@BUILD_LIBARCHIVE_TRUE@	$(MKDIR_P) $(DEPS_PREFIX)/libarchive/build $(DEPS_PREFIX)/lib/pkgconfig
@BUILD_LIBARCHIVE_TRUE@	$(TAR) xf $(DEPS_CACHE)/libarchive-$(LIBARCHIVE_VERSION).tar.gz -C $(DEPS_PREFIX)/libarchive --strip-components=1 && \
@BUILD_LIBARCHIVE_TRUE@	cd $(DEPS_PREFIX)/libarchive && \
@BUILD_LIBARCHIVE_TRUE@	$(SED) -i -e 's|time_t ctime_sec, mtime_sec;|int64_t ctime_sec, mtime_sec;|' libarchive/archive_match.c && \
@BUILD_LIBARCHIVE_TRUE@	cd build && \
@BUILD_LIBARCHIVE_TRUE@	PKG_CONFIG="$(PKG_CONFIG_PLUS_BUNDLED_OSSL)" \
@BUILD_LIBARCHIVE_TRUE@	$(CONFIGURE_PFX) ../configure $(LT_GNU_LD_CACHE) --host=$(host) --build=$(build) --prefix="$(DEPS_PREFIX)" \
@BUILD_LIBARCHIVE_TRUE@		$(if $(STATICBUILD),--enable-static --disable-shared,--enable-shared --disable-static) \
@BUILD_LIBARCHIVE_TRUE@		--disable-tools --disable-tests $(LT_WITH_GNU_LD) --disable-bsdtar --disable-bsdcat --disable-bsdcpio \
@BUILD_LIBARCHIVE_TRUE@		--disable-bsdunzip --without-xml2 --without-expat $(if $(OPENSSL_CFLAGS),--with-openssl --with-zstd,--without-openssl --without-zstd) \
@BUILD_LIBARCHIVE_TRUE@		--without-nettle --without-mbedtls --without-lzo2 --without-lz4 --without-libiconv-prefix \
@BUILD_LIBARCHIVE_TRUE@		--without-iconv --without-libb2 --with-lzma --with-zlib --with-bz2lib \
@BUILD_LIBARCHIVE_TRUE@		CC="$(CC)" RANLIB="$(RANLIB)" AR="$(AR)" CXX="$(CXX)" LD="$(LD)" \
@BUILD_LIBARCHIVE_TRUE@		CFLAGS="$(CFLAGS) -I$(DEPS_PREFIX)/include $(OPENSSL_CFLAGS) $(LIBACL_CFLAGS) $(LZMA_CFLAGS) $(BZIP2_CFLAGS) $(ZLIB_CFLAGS) -D_POSIX_C_SOURCE" \
@BUILD_LIBARCHIVE_TRUE@		LDFLAGS="$(LDFLAGS) -L$(DEPS_PREFIX)/lib $(OPENSSL_LIBS) $(LIBACL_LIBS) $(LZMA_LIBS) $(BZIP2_LIBS) $(ZLIB_LIBS)" && \
@BUILD_LIBARCHIVE_TRUE@	$(MAKE_PFX) $(MAKE) $(MAKEFLAGS) && \
@BUILD_LIBARCHIVE_TRUE@	$(MAKE_PFX) $(MAKE) $(MAKEFLAGS) install
@BUILD_LIBARCHIVE_TRUE@	$(PKG_CONFIG_PLUS_BUNDLED_OSSL) --exists --print-errors libarchive
@BUILD_LIBARCHIVE_TRUE@	touch $@

