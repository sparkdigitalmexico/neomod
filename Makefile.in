                        $(foreach m,$(BUILD_EMBED_MANIFESTS),-F $(m))

@WASM_PLATFORM_FALSE@EMBED_TYPE := asm-inline
@WASM_PLATFORM_TRUE@EMBED_TYPE := cppembed
