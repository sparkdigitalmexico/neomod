#: src/App/Neomod/MainMenuTips.cpp:43
msgid "Press Alt + Enter to toggle Fullscreen."
msgstr "Нажмите Alt + Enter для переключения полноэкранного режима."

#: src/App/Neomod/MainMenuTips.cpp:44
msgid "Press Shift + F1 to open the in-game console."
msgstr "Нажмите Shift + F1 для открытия игровой консоли."

#: src/App/Neomod/MainMenuTips.cpp:45
msgid "Shift + Click on a skin in the dropdown list to change the source for base skin elements."
msgstr "Shift + Клик по скину в выпадающем списке, чтобы изменить источник базовых элементов скина."

#: src/App/Neomod/MainMenuTips.cpp:48
#, c++-format
msgid "Press {:s} during gameplay to change mods in realtime."
msgstr "Нажмите {:s} во время игры, чтобы изменить моды в реальном времени."

#: src/App/Neomod/MainMenuTips.cpp:53
#, c++-format
msgid "Press {:s} or {:s} anywhere to open chat."
msgstr "Нажмите {:s} или {:s} в любом месте, чтобы открыть чат."

#: src/App/Neomod/MainMenuTips.cpp:59
msgid "Launch with the neomod-BASS shortcut to use BASS (ASIO/Exclusive mode) for audio."
msgstr "Запустите через ярлык neomod-BASS, чтобы использовать BASS (ASIO/Exclusive mode) для звука."

#: src/App/Neomod/MainMenuTips.cpp:61
msgid "Launch with \"-sound bass\" as a commandline argument to use BASS for audio."
msgstr "Запустите с аргументом командной строки \"-sound bass\", чтобы использовать BASS для звука."

#: src/App/Neomod/MainMenuTips.cpp:66
msgid "Put \"-gpu\" after the \"Target:\" field in a shortcut to neomod to use the D3D12 renderer."
msgstr "Добавьте \"-gpu\" в поле \"Объект:\" ярлыка neomod, чтобы использовать рендерер D3D12."

#: src/App/Neomod/MainMenuTips.cpp:67
msgid "Put \"-gpu vk\" after the \"Target:\" field in a shortcut to neomod to use the Vulkan renderer."
msgstr "Добавьте \"-gpu vk\" в поле \"Объект:\" ярлыка neomod, чтобы использовать рендерер Vulkan."

#: src/App/Neomod/MainMenuTips.cpp:69
msgid "Launch with \"-sdlgpu\" as a commandline argument to use the Vulkan renderer."
msgstr "Запустите с аргументом командной строки \"-sdlgpu\", чтобы использовать рендерер Vulkan."

#: src/App/Neomod/MainMenuTips.cpp:74
msgid "Put \"-dx11\" after the \"Target:\" field in a shortcut to neomod to use the D3D11 renderer."
msgstr "Добавьте \"-dx11\" в поле \"Объект:\" ярлыка neomod, чтобы использовать рендерер D3D11."

#: src/App/Neomod/MainMenuTips.cpp:76
msgid "Launch with \"-dx11\" as a commandline argument to use the D3D11 renderer."
msgstr "Запустите с аргументом командной строки \"-dx11\", чтобы использовать рендерер D3D11."

#: src/App/Neomod/MainMenuTips.cpp:80
msgid "Press Ctrl + O to open the options menu from anywhere."
msgstr "Нажмите Ctrl + O, чтобы открыть меню настроек из любого места."

