#: src/App/Neomod/MainMenuTips.cpp
msgid "Press Alt + Enter to toggle Fullscreen."
msgstr "Appuyez sur Alt + Entrée pour passer en plein écran."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Press Shift + F1 to open the in-game console."
msgstr "Appuyez sur Shift + F1 pour ouvrir la console de commandes."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Shift + Click on a skin in the dropdown list to change the source for base skin elements."
msgstr "Shift + Cliquez sur un skin dans la liste pour changer le skin par défaut."

#: src/App/Neomod/MainMenuTips.cpp
#, c++-format
msgid "Press {:s} during gameplay to change mods in realtime."
msgstr "Appuyez sur {:s} en jeu pour changer les mods en direct."

#: src/App/Neomod/MainMenuTips.cpp
#, c++-format
msgid "Press {:s} or {:s} anywhere to open chat."
msgstr "Appuyez sur {:s} ou {:s} n'import où pour ouvrir le chat."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with the neomod-BASS shortcut to use BASS (ASIO/Exclusive mode) for audio."
msgstr "Lancez avec le raccourci neomod-BASS pour utiliser le moteur audio BASS (ASIO/Mode exclusif)."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with \"-sound bass\" as a commandline argument to use BASS for audio."
msgstr "Lancez avec \"-sound bass\" en argument de ligne de commande pour utiliser le moteur audio BASS."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Put \"-gpu\" after the \"Target:\" field in a shortcut to neomod to use the D3D12 renderer."
msgstr "Lancez avec \"-gpu\" en argument de ligne de commande pour utiliser le moteur de rendu D3D12."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Put \"-gpu vk\" after the \"Target:\" field in a shortcut to neomod to use the Vulkan renderer."
msgstr "Lancez avec \"-vk\" en argument de ligne de commande pour utiliser le moteur de rendu Vulkan."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with \"-sdlgpu\" as a commandline argument to use the Vulkan renderer."
msgstr "Lancez avec \"-sdlgpu\" en argument de ligne de commande pour utiliser le moteur de rendu Vulkan."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Put \"-dx11\" after the \"Target:\" field in a shortcut to neomod to use the D3D11 renderer."
msgstr "Lancez avec \"-dx11\" en argument de ligne de commande pour utiliser le moteur de rendu D3D11."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with \"-dx11\" as a commandline argument to use the D3D11 renderer."
msgstr "Lancez avec \"-dx11\" en argument de ligne de commande pour utiliser le moteur de rendu D3D11."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Press Ctrl + O to open the options menu from anywhere."
msgstr "Appuyez sur Ctrl + O pour ouvrir le menu des options n'importe où."

#: src/App/Neomod/MainMenuTips.cpp
#, c++-format
msgid "Tip: {:s}"
msgstr "Astuce : {:s}"

