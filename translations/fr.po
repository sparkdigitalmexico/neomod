#, c++-format
msgid "Press {:s} or {:s} anywhere to open chat."
msgstr "Appuyez sur {:s} ou {:s} n'import où pour ouvrir le chat."

#: src/App/Neomod/MainMenuTips.cpp:59
msgid ""
"Launch with the neomod-BASS shortcut to use BASS (ASIO/Exclusive mode) for "
"audio."
msgstr ""
"Lancez avec le raccourci neomod-BASS pour utiliser le moteur audio BASS "
"(ASIO/Mode exclusif)."

#: src/App/Neomod/MainMenuTips.cpp:61
msgid ""
"Launch with \"-sound bass\" as a commandline argument to use BASS for audio."
msgstr ""
"Lancez avec \"-sound bass\" en argument de ligne de commande pour utiliser "
"le moteur audio BASS."

#: src/App/Neomod/MainMenuTips.cpp:66
msgid ""
"Put \"-gpu\" after the \"Target:\" field in a shortcut to neomod to use the "
"D3D12 renderer."
msgstr ""
"Lancez avec \"-gpu\" en argument de ligne de commande pour utiliser le "
"moteur de rendu D3D12."

#: src/App/Neomod/MainMenuTips.cpp:67
msgid ""
"Put \"-gpu vk\" after the \"Target:\" field in a shortcut to neomod to use "
"the Vulkan renderer."
msgstr ""
"Lancez avec \"-vk\" en argument de ligne de commande pour utiliser le moteur "
"de rendu Vulkan."

#: src/App/Neomod/MainMenuTips.cpp:69
msgid ""
"Launch with \"-sdlgpu\" as a commandline argument to use the Vulkan renderer."
msgstr ""
"Lancez avec \"-sdlgpu\" en argument de ligne de commande pour utiliser le "
"moteur de rendu Vulkan."

#: src/App/Neomod/MainMenuTips.cpp:74
msgid ""
"Put \"-dx11\" after the \"Target:\" field in a shortcut to neomod to use the "
"D3D11 renderer."
msgstr ""
"Lancez avec \"-dx11\" en argument de ligne de commande pour utiliser le "
"moteur de rendu D3D11."

#: src/App/Neomod/MainMenuTips.cpp:76
msgid ""
"Launch with \"-dx11\" as a commandline argument to use the D3D11 renderer."
msgstr ""
"Lancez avec \"-dx11\" en argument de ligne de commande pour utiliser le "
"moteur de rendu D3D11."

