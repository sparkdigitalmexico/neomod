#: src/App/Neomod/MainMenuTips.cpp
msgid "Press Alt + Enter to toggle Fullscreen."
msgstr "Drücke Alt + Enter für den Vollbildmodus."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Press Shift + F1 to open the in-game console."
msgstr "Drücke Shift + F1, um die Ingame-Konsole zu öffnen."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Shift + Click on a skin in the dropdown list to change the source for base skin elements."
msgstr "Shift + Klick auf einen Skin im Dropdown-Menü, um die Quelle für die Basis-Skin-Elemente zu ändern."

#: src/App/Neomod/MainMenuTips.cpp
#, c++-format
msgid "Press {:s} during gameplay to change mods in realtime."
msgstr "Drücke {:s} während des Spielens, um Mods in Echtzeit zu ändern."

#: src/App/Neomod/MainMenuTips.cpp
#, c++-format
msgid "Press {:s} or {:s} anywhere to open chat."
msgstr "Drücke {:s} oder {:s} überall, um den Chat zu öffnen."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with the neomod-BASS shortcut to use BASS (ASIO/Exclusive mode) for audio."
msgstr "Starte mit der neomod-BASS-Verknüpfung, um BASS (ASIO/Exklusiv-Modus) für Audio zu nutzen."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with \"-sound bass\" as a commandline argument to use BASS for audio."
msgstr "Starte mit \"-sound bass\" als Kommandozeilenargument, um BASS für Audio zu verwenden."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Put \"-gpu\" after the \"Target:\" field in a shortcut to neomod to use the D3D12 renderer."
msgstr "Setze \"-gpu\" hinter das \"Ziel:\"-Feld in einer Verknüpfung zu neomod, um den D3D12-Renderer zu nutzen."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Put \"-gpu vk\" after the \"Target:\" field in a shortcut to neomod to use the Vulkan renderer."
msgstr "Setze \"-gpu vk\" hinter das \"Ziel:\"-Feld in einer Verknüpfung zu neomod, um den Vulkan-Renderer zu nutzen."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with \"-sdlgpu\" as a commandline argument to use the Vulkan renderer."
msgstr "Starte mit \"-sdlgpu\" als Kommandozeilenargument, um den Vulkan-Renderer zu verwenden."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Put \"-dx11\" after the \"Target:\" field in a shortcut to neomod to use the D3D11 renderer."
msgstr "Setze \"-dx11\" hinter das \"Ziel:\"-Feld in einer Verknüpfung zu neomod, um den D3D11-Renderer zu nutzen."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Launch with \"-dx11\" as a commandline argument to use the D3D11 renderer."
msgstr "Starte mit \"-dx11\" als Kommandozeilenargument, um den D3D11-Renderer zu verwenden."

#: src/App/Neomod/MainMenuTips.cpp
msgid "Press Ctrl + O to open the options menu from anywhere."
msgstr "Drücke Strg + O, um das Optionsmenü von überall aus zu öffnen."

