msgstr "Dźwięk"

#: ../src/App/Neomod/OptionsOverlay.cpp:1111
#, no-c-format
msgid "Devices"
msgstr "Urządzenia"

#: ../src/App/Neomod/OptionsOverlay.cpp:1114
#, no-c-format
msgid "Default"
msgstr "Domyślne"

#: ../src/App/Neomod/OptionsOverlay.cpp:1114
#, no-c-format
msgid "Select Output Device"
msgstr "Wybierz urządzenie wyjściowe"

#: ../src/App/Neomod/OptionsOverlay.cpp:1127
#, no-c-format
msgid "Backend"
msgstr "Backend"

#: ../src/App/Neomod/OptionsOverlay.cpp:1127
#, no-c-format
msgid "MiniAudio"
msgstr "MiniAudio"

#: ../src/App/Neomod/OptionsOverlay.cpp:1127
#, no-c-format
msgid "SDL"
msgstr "SDL"

#: ../src/App/Neomod/OptionsOverlay.cpp:1138
#, no-c-format
msgid ""
"Pick the one you feel works best,\n"
"there should be very little difference."
msgstr ""
"Wybierz ten, który działa najlepiej według ciebie,\n"
"nie powinno być wielkiej różnicy."

#: ../src/App/Neomod/OptionsOverlay.cpp:1169
#, no-c-format
msgid "Auto-disable exclusive mode"
msgstr "Automatycznie wyłączaj tryb wyłączności"

#: ../src/App/Neomod/OptionsOverlay.cpp:1170
#, no-c-format
msgid ""
"Toggle exclusive mode off/on\n"
"when losing/gaining focus, if already\n"
"in exclusive mode."
msgstr ""
"Przełącza tryb wyłączności (wył./wł.)\n"
"przy utracie/odzyskaniu okna, jeśli już\n"
"jest w trybie wyłączności."

