msgstr "Przezroczystość Wnętrza Slidera"

#: ../src/App/Neomod/OptionsOverlay.cpp:1404
#, no-c-format
msgid "Slider Body Saturation"
msgstr "Nasycenie Wnętrza Slidera"

#: ../src/App/Neomod/OptionsOverlay.cpp:1406
#, no-c-format
msgid "Use slidergradient.png"
msgstr "Użyj slidergradient.png"

#: ../src/App/Neomod/OptionsOverlay.cpp:1407
#, no-c-format
msgid ""
"Enabling this will improve performance,\n"
"but also block all dynamic slider (color/border) features."
msgstr ""
"Włączenie tego poprawi wydajność,\n"
"ale zablokuje wszystkie dynamiczne funkcje slidera (kolory/ramki)."

#: ../src/App/Neomod/OptionsOverlay.cpp:1409
#, no-c-format
