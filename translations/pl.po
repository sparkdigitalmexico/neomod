msgstr "Tryb Wyłączności"

#: /Users/wh/dev/neomod/src/App/Neomod/OptionsOverlay.cpp:1205
msgid "Dramatically reduces latency, but prevents other applications from capturing/playing audio."
msgstr "Radykalnie zmniejsza opóźnienia, ale uniemożliwia innym aplikacjom przechwytywanie/odtwarzanie dźwięku."

#: /Users/wh/dev/neomod/src/App/Neomod/OptionsOverlay.cpp:1209
msgid "WARNING: Only if you know what you are doing"
msgstr "OSTRZEŻENIE: Tylko jeśli wiesz, co robisz"

