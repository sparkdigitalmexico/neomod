#, no-c-format
msgid "Low-latency Callbacks"
msgstr "Callbacki z niskim opóźnieniem"

#: ../src/App/Neomod/OptionsOverlay.cpp:1189
#, no-c-format
msgid ""
"Run BASSWASAPI in callback mode to potentially further decrease latency.\n"
"(period/buffer size are ignored)"
msgstr ""
"Uruchom BASSWASAPI w trybie callback, aby potencjalnie jeszcze bardziej "
"zmniejszyć opóźnienia.\n"
"(rozmiar okresu/bufora jest ignorowany)"

