#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:44
msgid "Press Shift + F1 to open the in-game console."
msgstr "Naciśnij Shift + F1, aby otworzyć konsolę w grze."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:45
msgid "Shift + Click on a skin in the dropdown list to change the source for base skin elements."
msgstr "Shift + Kliknięcie na skina z listy rozwijanej zmienia źródło podstawowych elementów skina."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:48
#, c++-format
msgid "Press {:s} during gameplay to change mods in realtime."
msgstr "Naciśnij {:s} podczas gry, aby zmienić mody w czasie rzeczywistym."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:53
#, c++-format
msgid "Press {:s} or {:s} anywhere to open chat."
msgstr "Naciśnij {:s} lub {:s} gdziekolwiek, aby otworzyć czat."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:59
msgid "Launch with the neomod-BASS shortcut to use BASS (ASIO/Exclusive mode) for audio."
msgstr "Uruchom za pomocą skrótu neomod-BASS, aby używać BASS (tryb ASIO/Wyłączności) dla dźwięku."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:61
msgid "Launch with \"-sound bass\" as a commandline argument to use BASS for audio."
msgstr "Uruchom z argumentem wiersza poleceń \"-sound bass\", aby używać BASS dla dźwięku."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:66
msgid "Put \"-gpu\" after the \"Target:\" field in a shortcut to neomod to use the D3D12 renderer."
msgstr "Dodaj \"-gpu\" po polu \"Element docelowy:\" w skrócie do neomod, aby użyć renderera D3D12."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:67
msgid "Put \"-gpu vk\" after the \"Target:\" field in a shortcut to neomod to use the Vulkan renderer."
msgstr "Dodaj \"-gpu vk\" po polu \"Element docelowy:\" w skrócie do neomod, aby użyć renderera Vulkan."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:69
msgid "Launch with \"-sdlgpu\" as a commandline argument to use the Vulkan renderer."
msgstr "Uruchom z argumentem wiersza poleceń \"-sdlgpu\", aby użyć renderera Vulkan."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:74
msgid "Put \"-dx11\" after the \"Target:\" field in a shortcut to neomod to use the D3D11 renderer."
msgstr "Dodaj \"-dx11\" po polu \"Element docelowy:\" w skrócie do neomod, aby użyć renderera D3D11."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:76
msgid "Launch with \"-dx11\" as a commandline argument to use the D3D11 renderer."
msgstr "Uruchom z argumentem wiersza poleceń \"-dx11\", aby użyć renderera D3D11."

#: /Users/wh/dev/neomod/src/App/Neomod/MainMenuTips.cpp:80
msgid "Press Ctrl + O to open the options menu from anywhere."
msgstr "Naciśnij Ctrl + O, aby otworzyć menu opcji z dowolnego miejsca."

