msgstr "Windows 7: Zacznij od 11 ms,"

#: /Users/wh/dev/neomod/src/App/Neomod/OptionsOverlay.cpp:1200
msgid "Windows 10: Start at 1 ms,"
msgstr "Windows 10: Zacznij od 1 ms,"

#: /Users/wh/dev/neomod/src/App/Neomod/OptionsOverlay.cpp:1201
msgid "and if crackling: increment until fixed."
msgstr "a jeśli trzeszczy: zwiększaj aż do naprawienia."

#: /Users/wh/dev/neomod/src/App/Neomod/OptionsOverlay.cpp:1202
msgid "(lower is better, non-wasapi has ~40 ms minimum)"
msgstr "(mniej znaczy lepiej, non-wasapi ma minimum ~40 ms)"

#: /Users/wh/dev/neomod/src/App/Neomod/OptionsOverlay.cpp:1204
