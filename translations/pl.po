msgstr "Rozstawienie smugi kursora:"

#: ../src/App/Neomod/OptionsOverlay.cpp:1394
#, no-c-format
msgid "Cursor Size:"
msgstr "Rozmiar Kursora:"

#: ../src/App/Neomod/OptionsOverlay.cpp:1397
#, no-c-format
msgid "Automatic Cursor Size"
msgstr "Automatyczny Rozmiar Kursora"

#: ../src/App/Neomod/OptionsOverlay.cpp:1397
#, no-c-format
