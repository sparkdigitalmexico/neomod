# KNOWN-BAD until phase 2 (event-driven mouse): a press+release arriving in the same
# frame is silently lost by the polled click synthesis (see Mouse.h "jank at low FPS" TODO).
# rename to .txt when phase 2 lands; the trace must then contain downInside+upInside
# on mainmenu_cube and the menu must expand.
options_save_on_back 0
debug_fixed_frametime 0.0166667
ui_trace 1
mouse_raw_input 0
mouse_sensitivity 1
ui_scale_to_dpi 0
windowed_resolution 1280x720
mouse_to 10 10
@wait 30
mouse_to 640 360
@wait 2
mouse_down
mouse_up
@wait 30
mouse_to 867 401
@wait 3
ui_assert hovered mainmenu_options 1
exit
